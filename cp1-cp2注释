# Cell: 从一个 32 位整数中提取 RGB 分量
def get_color(t):
    a = (t & 0x00ff0000) >> 16  # 取红色通道：屏蔽并向右移16位
    b = (t & 0x0000ff00) >> 8   # 取绿色通道
    c = t & 0x000000ff          # 取蓝色通道
    return a, b, c

c = 4287090426
r, g, b = get_color(c)
print(r, g, b)  # 输出各通道数值

