# Cell: 自己实现十进制到二进制的转换（整数部分）
def dec2bin(target):
    amari = []                # 用于保存余数（从低位到高位）
    while target != 0:
        amari.append(target % 2)  # 取余得到当前最低位
        target = target // 2      # 整除，注意：// 是整除（向下取整）
    amari.reverse()           # 余数序列是从低位到高位，反转得到高->低
    return amari

dec2bin(26)  # 示例：26 -> [1,1,0,1,0]

