# Cell: 扩展的整数与小数部分二进制转换示例
def dec2bin_ex(target):
    i = int(target)     # 整数部分
    f = target - i      # 小数部分
    a = []
    while (i != 0):
        a.append(i % 2)  # 向列表末尾添加当前位（低位先添加）
        i = i // 2
    a.reverse()          # 反转得到高位到低位的顺序
    b = []
    n = 0
    while (f != 0):
        temp = f * 2
        b.append(int(temp))       # 取整得到当前小数位
        f = temp - int(temp)      # 更新剩余小数部分
        n += 1
        if (n >= 10):             # 限制位数，避免无限循环或浮点精度问题
            break
    return a, b

dec2bin_ex(10.625)  # 举例：10.625 -> 整数部分 [1,0,1,0], 小数部分 [1,0,1]

