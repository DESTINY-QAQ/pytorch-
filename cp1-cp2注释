# Cell: 通用进制转换函数（任意进制字符串 -> 十进制）
def any2dec(target, m):
    # 注意：变量名不要用内建函数名（如 sum）以免覆盖内建函数
    n = len(target) - 1  # 指数，从最高位开始递减
    total = 0
    for i in range(len(target)):
        # 处理十六进制的 A-F
        ch = target[i].upper()  # 统一转大写，避免 'a'/'A' 问题
        if ch == 'A':
            num = 10
        elif ch == 'B':
            num = 11
        elif ch == 'C':
            num = 12
        elif ch == 'D':
            num = 13
        elif ch == 'E':
            num = 14
        elif ch == 'F':
            num = 15
        else:
            # 如果是数字字符，转为 int；若遇到非法字符会抛出 ValueError
            num = int(ch)
        total += (m ** n) * num
        n -= 1
    return total

ans1 = any2dec('1A', 16)         # 1A(16) -> 26
ans2 = any2dec('11111111', 2)    # 11111111(2) -> 255
print(f"{ans1},{ans2}")

